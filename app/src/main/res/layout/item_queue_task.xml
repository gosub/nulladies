<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="8dp"
    android:minHeight="56dp">

    <!-- Color dot -->
    <View
        android:id="@+id/color_dot"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginEnd="12dp" />

    <!-- Title -->
    <TextView
        android:id="@+id/task_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="15sp"
        android:textColor="@color/text_primary" />

    <!-- Reorder buttons -->
    <ImageButton
        android:id="@+id/btn_up"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_up"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Move up" />

    <ImageButton
        android:id="@+id/btn_down"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_down"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Move down" />

    <!-- Split -->
    <ImageButton
        android:id="@+id/btn_split"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_split"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Split" />

    <!-- Done -->
    <ImageButton
        android:id="@+id/btn_done"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_check"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Mark done" />

    <!-- Delete -->
    <ImageButton
        android:id="@+id/btn_delete"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_delete"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Delete" />

</LinearLayout>
