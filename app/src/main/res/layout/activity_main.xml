<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Main content area with FAB overlay -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="80dp">

                <!-- Current task card -->
                <LinearLayout
                    android:id="@+id/current_task_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/bg_current_task"
                    android:paddingStart="12dp"
                    android:paddingEnd="4dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:visibility="gone">

                    <View
                        android:id="@+id/current_task_color_bar"
                        android:layout_width="5dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/current_task_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/btn_done"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_check"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Done" />

                    <ImageButton
                        android:id="@+id/btn_split"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_split"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Split"
                        android:visibility="gone" />

                    <ImageButton
                        android:id="@+id/btn_skip"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_skip"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Skip" />

                </LinearLayout>

                <!-- All done message -->
                <TextView
                    android:id="@+id/all_done_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/all_tasks_complete"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:padding="24dp"
                    android:visibility="gone" />

                <!-- Unified task grid -->
                <LinearLayout
                    android:id="@+id/task_grid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/grid_padding"
                    android:paddingEnd="@dimen/grid_padding"
                    android:paddingTop="8dp"
                    android:paddingBottom="6dp" />

            </LinearLayout>
        </ScrollView>

        <!-- FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_quick_add"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="@dimen/fab_margin"
            android:contentDescription="Add task"
            app:srcCompat="@drawable/ic_add"
            app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.Full" />

    </FrameLayout>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>
