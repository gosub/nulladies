<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_back"
        app:title="Todo Queue"
        app:menu="@menu/toolbar_queue" />

    <!-- Info label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Items stay in the queue until marked done. Queue Slots pull from the top."
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:padding="8dp" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/queue_empty_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Queue is empty. Tap + Add to add a task."
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone" />

    <!-- List -->
    <ListView
        android:id="@+id/queue_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@color/divider"
        android:dividerHeight="1dp" />

</LinearLayout>
