<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_back"
        app:title="Settings" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Day Rollover Time -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Day Rollover Time"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The day resets at this time. Default: 00:00"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/rollover_time_display"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="00:00"
                    android:textSize="20sp"
                    android:textColor="@color/text_primary" />

                <Button
                    android:id="@+id/btn_pick_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Change" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <!-- Backup Folder -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Org-mode Backup Folder"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The app writes nulladies_backup.org to this folder on every change."
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/backup_folder_display"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Not set"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_pick_folder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choose Folder" />

            <!-- Debug section (shown only in debug builds via BuildConfig.DEBUG) -->
            <LinearLayout
                android:id="@+id/debug_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Debug"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btn_debug_reset_today"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reset today"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btn_debug_db_stats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DB stats"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btn_debug_wipe_db"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Wipe database" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
